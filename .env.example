# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hackathon2026

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=chunks

# LLM. Клиент (src/llm.py) сам выбирает протокол по URL (переопределить: LLM_PROVIDER=openai|ollama):
#   api.ollama.com -> нативный Ollama /api/chat; всё остальное -> OpenAI-совместимый /v1.
#
# Yandex AI Studio (ключ от организаторов хакатона):
#   LLM_BASE_URL=https://llm.api.cloud.yandex.net/v1
#   LLM_API_KEY=<API-ключ>
#   LLM_MODEL=gpt://<folder_id>/yandexgpt/latest   # точное имя модели — из письма организаторов
# Облачный Ollama:  LLM_BASE_URL=https://api.ollama.com  LLM_API_KEY=<ключ>  LLM_MODEL=gemma3:12b
# Ollama локально:  LLM_BASE_URL=http://localhost:11434/v1  LLM_API_KEY=ollama  LLM_MODEL=qwen3:14b
LLM_BASE_URL=https://api.ollama.com
LLM_API_KEY=
LLM_MODEL=gemma3:12b

# Эмбеддинги (e5-small для разработки, BGE-M3 для боя)
# EMBED_MODEL=BAAI/bge-m3
EMBED_MODEL=intfloat/multilingual-e5-small

# UI -> API
API_URL=http://localhost:8000
